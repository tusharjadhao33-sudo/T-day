<script>
const API_KEY = "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";

const messagesDiv = document.getElementById("messages");

/* Store conversation */
let chatHistory = [
  {
    role: "system",
    content: `
You are Tushar Spark ⚡, a highly intelligent assistant.

Rules:
- Answer ANY question (life, study, coding, math, advice)
- Keep answers clear and helpful
- For math: show steps simply
- For coding: give clean code + short explanation
- Be friendly but smart
- Use emojis sometimes
`
  }
];

/* Add message */
function addMessage(text, type) {
  const div = document.createElement("div");
  div.className = "msg " + type;
  div.innerText = text;
  messagesDiv.appendChild(div);
  messagesDiv.scrollTop = messagesDiv.scrollHeight;
  return div;
}

/* AI Response */
async function getAIResponse(userText) {
  chatHistory.push({ role: "user", content: userText });

  const typing = addMessage("Thinking...", "bot");

  try {
    const res = await fetch("https://api.openai.com/v1/chat/completions", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": "Bearer " + API_KEY
      },
      body: JSON.stringify({
        model: "gpt-4o-mini",
        messages: chatHistory,
        temperature: 0.7
      })
    });

    const data = await res.json();
    typing.remove();

    const reply = data.choices[0].message.content;

    chatHistory.push({ role: "assistant", content: reply });

    return reply;

  } catch (e) {
    typing.remove();
    return "⚠️ Error connecting to AI";
  }
}

/* Send */
async function sendMessage() {
  const input = document.getElementById("userInput");
  const text = input.value.trim();
  if (!text) return;

  addMessage(text, "user");
  input.value = "";

  const reply = await getAIResponse(text);
  addMessage(reply, "bot");
}

/* Voice */
function startVoice() {
  const rec = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
  rec.lang = "en-IN";

  rec.onresult = function(e) {
    document.getElementById("userInput").value = e.results[0][0].transcript;
    sendMessage();
  };

  rec.start();
}
</script>
